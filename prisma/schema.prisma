generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model SearchHistory {
  id           String   @id @default(cuid())
  query        String
  timestamp    DateTime @default(now())
  resultsCount Int
}

model Product {
  id          String   @id @default(cuid())
  mlId        String   @unique
  name        String
  imageUrl    String?
  lastSeen    DateTime @default(now())
}
